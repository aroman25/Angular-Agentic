OPENAI_API_KEY=xxx

# Work-order mode: dual | strict | observe
ORCH_WORK_ORDER_MODE=dual

# Retrieval controls
ORCH_RETRIEVAL_ENABLED=true
ORCH_RETRIEVAL_MAX_CHARS_PLANNER=5200
ORCH_RETRIEVAL_MAX_CHARS_DEVELOPER=4200
ORCH_RETRIEVAL_MAX_CHARS_VALIDATOR=3600

# Rule selection limits
ORCH_RULE_MAX_COUNT_PLANNER=18
ORCH_RULE_MAX_COUNT_DEVELOPER=20
ORCH_RULE_MAX_COUNT_VALIDATOR=16

# Prompt/output shaping
ORCH_PROMPT_MAX_CHARS_PLANNER=22000
ORCH_PROMPT_MAX_CHARS_DEVELOPER=20000
ORCH_PROMPT_MAX_CHARS_VALIDATOR=18000
ORCH_PROMPT_USER_STORY_MAX_CHARS=8000
ORCH_PROMPT_VALIDATION_FEEDBACK_MAX_CHARS=4000
ORCH_EXECUTION_BRIEF_MAX_CHARS=5500

# Tool output caps
ORCH_TOOL_READ_FILE_MAX_CHARS=18000
ORCH_TOOL_COMMAND_SUCCESS_MAX_CHARS=5000
ORCH_TOOL_COMMAND_FAILURE_MAX_CHARS=9000
ORCH_TOOL_COMMAND_IMPORTANT_LINES=120

# Retry/delta controls
ORCH_RETRY_DELTA_ONLY=true
ORCH_RETRY_INCLUDE_FULL_WORKORDER_ON_FIRST_ATTEMPT=true

# Disk-backed command logs
ORCH_LOGS_ENABLED=true
ORCH_LOGS_MAX_RUNS=20
ORCH_LOGS_MAX_AGE_DAYS=14
ORCH_LOGS_TAIL_LINES_DEFAULT=120

# Token budgets (estimated tokens per role prompt, reserve is kept for system overhead)
ORCH_TOKEN_BUDGET_PLANNER=14000
ORCH_TOKEN_BUDGET_DEVELOPER=12000
ORCH_TOKEN_BUDGET_VALIDATOR=10000
ORCH_TOKEN_BUDGET_RESERVE=800

# Model routing and escalation
ORCH_MODEL_PLAN_BASE=gpt-5-nano
ORCH_MODEL_DEV_BASE=gpt-5-nano
ORCH_MODEL_VALIDATE_BASE=gpt-5-nano
ORCH_MODEL_PLAN_ESCALATED=gpt-5-mini
ORCH_MODEL_VALIDATE_ESCALATED=gpt-5-mini
ORCH_MODEL_ESCALATE_AFTER_PLANNER_FAILURES=2
ORCH_MODEL_ESCALATE_AFTER_VALIDATOR_FAILURES=2

# Hybrid validator gate
ORCH_VALIDATOR_HYBRID_CONFIDENCE_THRESHOLD=0.85
